<Window x:Class="Notepad.CustomDialog.SettingsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:Notepad.CustomDialog"
        mc:Ignorable="d"
        Title="Settings" Width="300" Height="200">
     
        
        
        
  
        
        
        <Grid Background="{DynamicResource Theme_BackgroundBrush}">
                <RadioButton x:Name="InformationlogLevelButton" Click="InformationlogLevelButton_OnClick" Content="Information Log Level" Margin="48,56,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="140" Height="32" />
                <RadioButton x:Name="DebugLogLevelButton" Click="DebugLogLevelButton_OnClick" Content="Debug Log Level" Margin="48,96,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" Width="120" Height="32" />
        </Grid>
        
        
        
        
        
</Window>
