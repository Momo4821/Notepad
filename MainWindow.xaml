<Window
    x:Class="Notepad.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Notepad"
    Width="800"
    Height="450"
    Icon="C:\Users\malan\source\repos\Notepad\Icon\Notepad_Icon.ico"
    mc:Ignorable="d">
    <Grid>
        <Menu>
            <MenuItem Header="File">
                <MenuItem
                    x:Name="New"
                    Click="New_OnClick"
                    Header="New" />
                <MenuItem
                    x:Name="OpenFile"
                    Click="OpenFile_OnClick"
                    Header="Open" />
                <MenuItem
                    x:Name="Save"
                    Click="Save_OnClick"
                    Header="Save" />
                <MenuItem
                    x:Name="SaveAs"
                    Click=" Save_As_OnClick"
                    Header="Save as" />
                <MenuItem
                    x:Name="Print"
                    Click="Print_OnClick"
                    Header="Print" />
            </MenuItem>
            <MenuItem Header="Edit">
                <MenuItem
                    x:Name="ChangeFont"
                    Click="Change_Font_OnClick"
                    Header="ChangeFont" />
                <MenuItem
                    x:Name="Time_DateStamp"
                    Click="Time_Date_Stamp_OnClick"
                    Header="Time_dateStamp" />
                <MenuItem
                    x:Name="Format"
                    Click="Format_OnClick"
                    Header="Format" />
            </MenuItem>
            <MenuItem
                x:Name="Exit"
                Width="42"
                Height="51"
                Click="Exit_OnClick"
                Header="Exit" />
            <MenuItem
                x:Name="Settings"
                Width="50"
                Height="51"
                Click="Settings_OnClick"
                Header="Settings" />
      
            <Label
                x:Name="LabelFilePath"
                Width="200"
                Height="10"
                Margin="102,20"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                HorizontalContentAlignment="Center"
              
                Content="" />
            <Label
                x:Name="LabelFileType"
                Width="200"
                Height="20"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Content="" />
        </Menu>
        <TextBox
            x:Name="Textbox_Main"
            Margin="10,51,19,19"
            Padding="10px"
            AcceptsReturn="True"
            AcceptsTab="True"
            FontFamily="Times New Roman"
            FontSize="20"
            IsReadOnly="False"
            KeyDown="Textbox_Main_OnKeyDown"
            Text=""
            TextWrapping="Wrap"
            VerticalScrollBarVisibility="Visible" />
       
        <Popup></Popup>
        
    </Grid>
</Window>
