<Window x:Class="Notepad.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"  
        Icon = "C:\Users\malan\source\repos\Notepad\Icon\Notepad_Icon.ico"
        Title="Notepad" Height="450" Width="800">
    <Grid>
        <Menu>
            <MenuItem Header="File">
                <MenuItem Header="New" x:Name="New" Click="New_OnClick"> </MenuItem>
                <MenuItem Header ="Open" x:Name="OpenFile" Click="OpenFile_OnClick"></MenuItem>
                <MenuItem Header="Save" x:Name="Save" Click="Save_OnClick"></MenuItem>
                <MenuItem Header="Save as" x:Name="SaveAs" Click=" Save_As_OnClick"></MenuItem>
                <MenuItem Header="Print" x:Name="Print" Click="Print_OnClick"></MenuItem>

            </MenuItem>

            <MenuItem Header="Edit">
                <MenuItem Header="ChangeFont" x:Name="ChangeFont" Click="Change_Font_OnClick"></MenuItem>
                <MenuItem Header="Time_dateStamp" x:Name="Time_DateStamp" Click="Time_Date_Stamp_OnClick"></MenuItem>
                <MenuItem Header="Format" x:Name="Format" Click="Format_OnClick"></MenuItem>
            </MenuItem>

            <MenuItem Header="Exit" x:Name="Exit" Height="51" Width="42" Click="Exit_OnClick"></MenuItem>
            <Label x:Name="LabelFilePath"  Height="20" Width="347" HorizontalAlignment="Center" VerticalAlignment="Center" />
            <Label x:Name="LabelFileType"  Height="20" Width="294" HorizontalAlignment="Center" VerticalAlignment="Center"/>



        </Menu>
        
       
        <TextBox x:Name="Textbox_Main" TextWrapping="Wrap" AcceptsReturn="True" Text="" AcceptsTab="True" Margin="10,51,19,19"  
                  VerticalScrollBarVisibility="Visible" KeyDown="Textbox_Main_OnKeyDown" Padding="10px" FontFamily="Times New Roman" FontSize="20" IsReadOnly="False"
               />
    </Grid>
</Window>
